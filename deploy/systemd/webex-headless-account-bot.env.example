# Copy to /etc/webex-headless/webex-headless-account-bot.env and set mode 0600.
# This file is parsed by systemd EnvironmentFile, so keep KEY=VALUE syntax.

# Raw access-token file published by webex-headless-token-refresh.service.
WEBEX_ACCESS_TOKEN_FILE=/var/lib/webex-headless-access/access-token

# Local forwarding token shared by the account bot and JS sidecar.
WEBEX_SIDECAR_TOKEN=

# Account bot listener and health check.
WEBEX_ACCOUNT_BOT_BIND=127.0.0.1:8787
WEBEX_ACCOUNT_BOT_PATH=/webex/events
WEBEX_ACCOUNT_BOT_HEALTH_PATH=/healthz
WEBEX_ACCOUNT_BOT_STATE_FILE=/var/lib/webex-headless-account-bot/processed-message-ids.txt

# Optional production filters and reply behavior.
WEBEX_ACCOUNT_BOT_ROOM_IDS=
WEBEX_ACCOUNT_BOT_SELF_PERSON_ID=
WEBEX_ACCOUNT_BOT_REPLY_PREFIX=ack
WEBEX_ACCOUNT_BOT_MAX_PROCESSED_IDS=10000

# Capacity and timeout knobs. Keep handler/in-flight waits below WEBEX_SIDECAR_FORWARD_TIMEOUT_MS.
WEBEX_ACCOUNT_BOT_MAX_CONCURRENT_CONNECTIONS=64
WEBEX_ACCOUNT_BOT_MAX_CONCURRENT_REQUESTS=16
WEBEX_ACCOUNT_BOT_REQUEST_READ_TIMEOUT_SECS=10
WEBEX_ACCOUNT_BOT_HANDLER_TIMEOUT_SECS=8
WEBEX_ACCOUNT_BOT_WEBEX_REQUEST_TIMEOUT_SECS=30
WEBEX_ACCOUNT_BOT_ATTEMPT_LEASE_SECS=30
WEBEX_ACCOUNT_BOT_IN_FLIGHT_WAIT_SECS=8
