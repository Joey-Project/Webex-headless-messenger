# Copy to /etc/webex-headless/webex-headless-receiver.env and set mode 0640.
# This file is parsed by systemd EnvironmentFile, so keep KEY=VALUE syntax.

# Local forwarding token shared by the Rust receiver and JS sidecar.
WEBEX_SIDECAR_TOKEN=

# Rust receiver settings.
WEBEX_SIDECAR_RECEIVER_BIND=127.0.0.1:8787
WEBEX_SIDECAR_RECEIVER_PATH=/webex/events
WEBEX_SIDECAR_RECEIVER_HEALTH_PATH=/healthz
