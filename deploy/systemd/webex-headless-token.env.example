# Copy to /etc/webex-headless/webex-headless-token.env and set mode 0600.
# This file is parsed by systemd EnvironmentFile, so keep KEY=VALUE syntax.

WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET_FILE=/etc/webex-headless/webex-client-secret
WEBEX_REFRESH_TOKEN_FILE=/var/lib/webex-headless-token/token.json
WEBEX_ACCESS_TOKEN_FILE=/var/lib/webex-headless-access/access-token
