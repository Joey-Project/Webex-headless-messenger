# Copy to /etc/webex-headless/webex-headless.env and set mode 0640.
# This file is parsed by systemd EnvironmentFile, so keep KEY=VALUE syntax.

WEBEX_TOKEN_FILE=/var/lib/webex-headless/token.json

# Local forwarding token shared by the Rust receiver and JS sidecar.
WEBEX_SIDECAR_TOKEN=

# JS sidecar settings.
WEBEX_SIDECAR_TARGET_URL=http://127.0.0.1:8787/webex/events
WEBEX_SIDECAR_HEALTH_BIND=127.0.0.1:8788
WEBEX_SIDECAR_TOKEN_RELOAD_INTERVAL_MS=60000
WEBEX_SIDECAR_FORWARD_RETRIES=3
WEBEX_SIDECAR_RETRY_BASE_MS=500
WEBEX_SIDECAR_RETRY_MAX_MS=5000
WEBEX_SIDECAR_FORWARD_TIMEOUT_MS=10000
WEBEX_SIDECAR_MAX_IN_FLIGHT=8
WEBEX_SIDECAR_MESSAGE_EVENTS=created,deleted
WEBEX_SIDECAR_HEALTH_PATH=/healthz
WEBEX_SIDECAR_READY_PATH=/readyz
WEBEX_SIDECAR_LIVE_PATH=/livez
WEBEX_SDK_LOG_LEVEL=error
